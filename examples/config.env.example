# termix-linkifier configuration examples
# Copy and modify these for your use case

# ── Example 1: File paths → Web viewer ──────────────────────────────────────
# ./install.sh --container termix \
#   --pattern '/opt/shared/' \
#   --url 'http://viewer.example.com/?file={path}' \
#   --color '#4fc3f7'

# ── Example 2: File paths → Clipboard ───────────────────────────────────────
# ./install.sh --container termix \
#   --pattern '/var/log/' \
#   --clipboard \
#   --color '#81c784'

# ── Example 3: JIRA tickets → Issue tracker ─────────────────────────────────
# ./install.sh --container termix \
#   --pattern 'JIRA-' \
#   --url 'https://jira.example.com/browse/{path}' \
#   --color '#ff9800'

# ── Example 4: Error codes → Documentation ──────────────────────────────────
# ./install.sh --container termix \
#   --regex 'ERR-[0-9]+' \
#   --url 'https://docs.example.com/errors/{path}' \
#   --color '#ef5350'

# ── Example 5: Local mode (no Docker) ───────────────────────────────────────
# ./install.sh --local \
#   --bundle-dir /srv/termix/html/assets \
#   --index-html /srv/termix/html/index.html \
#   --pattern '/home/' \
#   --clipboard
